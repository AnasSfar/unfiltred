collectors/spotify/charts/**/*.csv

# Browser profiles (large, auto-generated)
chrome_profile/
**/chrome_profile/

# Python cache
__pycache__/
*.pyc
*.pyo

# Session files (sensitive)
**/spotify_session.json
**/twitter_session.json
